{
  "name": "neutron-launcher",
  "version": "1.0.0",
  "description": "Neutron Launcher \u2014 A modern Minecraft launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder build --win --x64",
    "build:dir": "electron-builder build --dir",
    "build:portable": "electron-builder build --win portable",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.neutron.launcher",
    "productName": "Neutron Launcher",
    "extends": null
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "adm-zip": "^0.5.10",
    "msmc": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "author": {
    "name": "Neutron Team",
    "email": "neutronlauncherofficial@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://neutronlauncher.net"
}